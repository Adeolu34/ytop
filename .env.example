# MongoDB — primary data store (blog, CMS, users, forms, media metadata, etc.)
# Atlas: Cluster → Connect → Drivers → copy SRV string.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
# If the URI has no database name in the path, set it explicitly:
# MONGODB_DB="ytopglobal"
# Optional: npm run sync:blog-mongo (if you still sync published posts from another source)

# NextAuth (set NEXTAUTH_SECRET or AUTH_SECRET; both are read for JWT / middleware)
NEXTAUTH_SECRET="your-secret-key-here"
# AUTH_SECRET="same-as-above"
NEXTAUTH_URL="http://localhost:3000"
# Public site URL for share links and newsletter emails (optional; falls back to NEXTAUTH_URL)
# NEXT_PUBLIC_SITE_URL="https://ytopglobal.org"

# Admin seed credentials
ADMIN_EMAIL="admin@ytopglobal.org"
ADMIN_PASSWORD="replace-with-a-strong-password"
ADMIN_NAME="Admin User"

# WordPress Export (for migration scripts)
WORDPRESS_URL="https://ytopglobal.org"
WORDPRESS_USERNAME="admin"
WORDPRESS_APP_PASSWORD="your-wordpress-app-password"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email — Microsoft 365 / SMTP (used first if set; good for org mailboxes)
# Typical: smtp.office365.com, port 587, STARTTLS (SMTP_SECURE=false).
# With MFA, use an app password or an SMTP-enabled service account.
# SMTP_HOST="smtp.office365.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="newsletter@ytopglobal.org"
# SMTP_PASSWORD="your-password-or-app-password"
# SMTP_FROM="YTOP Global <newsletter@ytopglobal.org>"
# Optional: parallel sends per wave (default 8)
# SMTP_SEND_CONCURRENCY="8"
# Optional: only if your TLS chain fails in dev
# SMTP_TLS_REJECT_UNAUTHORIZED="false"

# Email (SendGrid) — used if SMTP is not configured
SENDGRID_API_KEY="SG...."
SENDGRID_FROM_EMAIL="noreply@ytopglobal.org"

# Or Email (Resend)
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="noreply@ytopglobal.org"

# MailChimp
MAILCHIMP_API_KEY="your-mailchimp-api-key"
MAILCHIMP_AUDIENCE_ID="your-audience-id"
MAILCHIMP_SERVER_PREFIX="us1"

# Cloudinary — admin gallery uploads (files in Cloudinary; metadata in Mongo `cms_media`)
# When all three are set, new uploads go to Cloudinary instead of public/uploads/admin.
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Optional folder prefix in Cloudinary (default: ytop/admin)
# CLOUDINARY_UPLOAD_FOLDER="ytop/admin"
# Optional: folder for bulk script upload-public-folder-to-cloudinary.ts (default: ytop/site-media)
# CLOUDINARY_STATIC_FOLDER="ytop/site-media"
# Public /gallery: comma-separated public_id prefixes (default: ytop/gallery). The admin upload folder
# (CLOUDINARY_UPLOAD_FOLDER, default ytop/admin) is merged in by default so Media Library images show.
# Tag assets e.g. Events, Programs, Community, Team for filters.
# CLOUDINARY_GALLERY_PREFIX="ytop/gallery"
# Only show those prefixes (hide admin uploads from /gallery):
# CLOUDINARY_GALLERY_ALSO_UPLOAD_FOLDER=0
# If most images use other public_id paths, either set CLOUDINARY_GALLERY_PREFIX to match (comma-separated),
# or list the whole account (paginated; caps at CLOUDINARY_GALLERY_MAX_IMAGES, default 5000):
# CLOUDINARY_GALLERY_ALL_IMAGES=1
# CLOUDINARY_GALLERY_MAX_IMAGES=5000

# Google Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
